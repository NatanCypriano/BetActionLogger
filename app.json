{
  "expo": {
    "name": "Bet Action Logger",
    "slug": "bet-action-logger",
    "scheme": "betactionlogger",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.natancypriano.betactionlogger",
      "versionCode": 1
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "2c01866a-af35-4485-99a7-c2ef4e0e42f0"
      }
    }
  }
}
